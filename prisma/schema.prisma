// This is your Prisma schema for the Health Consultation Booking App

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"   // Keep this path
}

datasource db {
  provider = "postgresql"               // Use PostgreSQL (or SQLite if you prefer)
  url      = env("DATABASE_URL")
}

// User roles
enum Role {
  ADMIN
  PATIENT
  DOCTOR
}

// Appointment status (mirrors on‑chain states, but stored off‑chain for UI)
enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique          // optional, can be used for notifications
  wallet    String   @unique          // Ethereum address
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())

  // Relations
  patientAppointments Appointment[] @relation("PatientAppointments")
  doctorAppointments  Appointment[] @relation("DoctorAppointments")
}

model Appointment {
  id                   String   @id @default(uuid())
  chainAppointmentId   BigInt   @unique   // The ID from the smart contract (uint256)
  patientId            String
  doctorId             String
  date                 DateTime           // Appointment date/time
  description          String             // Symptoms, notes (sensitive, stored off‑chain)
  status               AppointmentStatus @default(PENDING)
  createdAt            DateTime @default(now())

  // Relations
  patient User @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor  User @relation("DoctorAppointments",  fields: [doctorId],  references: [id])

  @@index([chainAppointmentId])
  @@index([patientId])
  @@index([doctorId])
}
